{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/main.tsx", "vite.config.ts", "vitest.config.ts"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/components/ui/**",
    "src/components/quick-pane/QuickPaneApp.tsx",
    "src/hooks/use-mobile.ts",
    "src/quick-pane-main.tsx",
    "**/index.ts"
  ],
  "ignoreDependencies": [
    "@tauri-apps/*",
    "@radix-ui/*",
    "tailwindcss",
    "tw-animate-css",
    "react-day-picker",
    "@testing-library/*",
    "@wdio/*",
    "babel-plugin-react-compiler"
  ],
  "ignoreExportsUsedInFile": true
}
