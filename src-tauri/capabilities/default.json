{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window. Least-privilege: only permissions actually invoked from the webview (Rust-side plugin usage does NOT require capabilities — it bypasses the IPC permission gate).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-maximized",
    "core:window:allow-is-fullscreen",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-create-webview-window",
    "core:event:default",
    "opener:default",
    "clipboard-manager:default",
    "dialog:default",
    "os:default",
    "process:default"
  ]
}
